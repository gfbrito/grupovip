# ──────────────────────────────────────────────────────────
# Variáveis de Ambiente — wpp-grupos
# Copie este arquivo para .env e preencha os valores reais
# ──────────────────────────────────────────────────────────

# ── PostgreSQL ─────────────────────────────────────────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=sua_senha_segura_aqui
POSTGRES_DB=wpp_grupos
POSTGRES_PORT=5432

# ── Backend ────────────────────────────────────────────────
BACKEND_PORT=3001
DATABASE_URL=postgresql://admin:sua_senha_segura_aqui@postgres:5432/wpp_grupos

# Segredo para geração de JWT (use uma string longa e aleatória)
JWT_SECRET=troque_por_um_segredo_muito_longo_e_aleatorio

# ── Frontend ───────────────────────────────────────────────
FRONTEND_PORT=3000

# URL da API acessível pelo browser do usuário final
# Em produção, use o domínio real: https://api.seudominio.com
NEXT_PUBLIC_API_URL=http://localhost:3001
